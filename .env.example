# =====================================================================
# .env.example
# Safe template only. Do NOT put real secrets in this file.
# =====================================================================

# --- Supabase Public (safe for frontend) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
NEXT_PUBLIC_SUPABASE_LEGACY_ANON_KEY=optional-legacy-public-key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-public-anon-key

# --- Supabase Private (server-only, never exposed to browser) ---
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_URL=https://your-project.supabase.co

# --- Database ---
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- WebSocket / Collaboration ---
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:1234
NEXT_PUBLIC_WS_URL=ws://localhost:1234
NEXT_PUBLIC_SOCKET_URL=ws://localhost:1234
HOCUSPOCUS_HOST=0.0.0.0
HOCUSPOCUS_PORT=1234
COLLAB_TOKEN_SECRET=replace-with-a-long-random-secret-min-24-chars
COLLAB_TOKEN_TTL_SECONDS=3600
COLLAB_DISABLE_PERSISTENCE=true
COLLAB_UPDATE_FLUSH_MS=1800
COLLAB_VERSION_INTERVAL=40

# --- AI (Groq, server-only) ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# --- Editor Config ---
NEXT_PUBLIC_EDITOR_DEFAULT_TITLE=Untitled document
NEXT_PUBLIC_ALLOW_GUEST_WRITE=true
NEXT_PUBLIC_DEFAULT_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# --- Deployment helper (used by docker-compose image references) ---
DOCKER_USERNAME=your-dockerhub-username